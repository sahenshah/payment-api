# Copy to .env and fill in real values. Never commit the actual .env file.

# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://payment_api:changeme@localhost:5432/payment_api
REDIS_URL=redis://localhost:6379
SQS_QUEUE_URL=https://sqs.eu-west-2.amazonaws.com/YOUR_ACCOUNT_ID/payment-api-audit-queue